// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  image          String?
  payday         Int?      // first payday
  payday2        Int?      // second payday 
  monthlyIncome  Decimal? @db.Decimal(10, 2)
  onboardingDone Boolean  @default(false)
  createdAt      DateTime @default(now())

  expenses  Expense[]
  budgets   Budget[]
  goals     SavingsGoal[]
  wallets   Wallet[]
}
 
model Expense {
  id          String    @id @default(cuid())
  amount      Decimal   @db.Decimal(10, 2)
  description String
  category    Category
  date        DateTime  @default(now())
  isRecurring Boolean   @default(false)
  isSplit     Boolean   @default(false)
  totalAmount Decimal?  @db.Decimal(10, 2)
  splitWith   String?
  yourShare   Decimal?  @db.Decimal(10, 2)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  walletId    String?
  wallet      Wallet?   @relation(fields: [walletId], references: [id])
  goalId      String?
  goal        SavingsGoal? @relation(fields: [goalId], references: [id])
}
model Budget {
  id        String   @id @default(cuid())
  category  Category
  limit     Decimal  @db.Decimal(10, 2)
  month     Int
  year      Int
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  @@unique([userId, category, month, year])
}
 
model SavingsGoal {
  id           String    @id @default(cuid())
  name         String
  targetAmount Decimal   @db.Decimal(10, 2)
  savedAmount  Decimal   @db.Decimal(10, 2) @default(0)
  deadline     DateTime?
  createdAt    DateTime  @default(now())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  expenses     Expense[]
}

model Wallet {
  id        String     @id @default(cuid())
  name      String
  type      WalletType
  balance   Decimal    @db.Decimal(10, 2) @default(0)
  color     String?
  icon      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  expenses  Expense[]
}
 
enum Category {
  RENT
  GROCERIES
  TRANSPORT
  FOOD
  UTILITIES
  LEISURE
  HEALTH
  SAVINGS
  OTHER
}
 
enum WalletType {
  CASH
  GCASH
  MAYA
  CREDIT_CARD
  DEBIT_CARD
  BANK
  OTHER
}
